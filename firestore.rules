rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /Trading_cards/{cardId} {

      function getVal(docData, field) {
        return docData.get(field, 0);
      }

      allow read: if true;

      allow create: if
        request.resource.data.get('likes', 0) <= 1 &&
        request.resource.data.get('dislikes', 0) <= 1 &&
        request.resource.data.get('ratingCount', 0) <= 1 &&
        request.resource.data.get('ratingSum', 0) >= 0 &&
        request.resource.data.get('ratingSum', 0) <= 5.0;

      allow update: if
        // Fall 1: Nur Like inkrementiert
        (request.resource.data.get('likes', 0) == getVal(resource.data, 'likes') + 1 &&
         request.resource.data.get('dislikes', 0) == getVal(resource.data, 'dislikes') &&
         request.resource.data.get('ratingCount', 0) == getVal(resource.data, 'ratingCount') &&
         request.resource.data.get('ratingSum', 0) == getVal(resource.data, 'ratingSum'))
        ||
        // Fall 2: Nur Dislike inkrementiert
        (request.resource.data.get('dislikes', 0) == getVal(resource.data, 'dislikes') + 1 &&
         request.resource.data.get('likes', 0) == getVal(resource.data, 'likes') &&
         request.resource.data.get('ratingCount', 0) == getVal(resource.data, 'ratingCount') &&
         request.resource.data.get('ratingSum', 0) == getVal(resource.data, 'ratingSum'))
        ||
        // Fall 3: Nur Rating inkrementiert (Count +1, Sum +[0.5 bis 5.0])
        (request.resource.data.get('ratingCount', 0) == getVal(resource.data, 'ratingCount') + 1 &&
         (request.resource.data.get('ratingSum', 0) - getVal(resource.data, 'ratingSum')) >= 0.5 &&
         (request.resource.data.get('ratingSum', 0) - getVal(resource.data, 'ratingSum')) <= 5.0 &&
         request.resource.data.get('likes', 0) == getVal(resource.data, 'likes') &&
         request.resource.data.get('dislikes', 0) == getVal(resource.data, 'dislikes'));
    }
  }
}
