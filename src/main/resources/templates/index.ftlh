<!DOCTYPE html>
<html lang="en">
<head>
    ${headHtml?no_esc}
</head>
<body>
${topNavHtml?no_esc}
<main class="detail-main" style="text-align: center; padding: 60px 20px;">
    <header class="detail-header">
        <h1 style="font-size: 2.8em; color: #333;">Welcome to the Maulmann Trading Cards Collection</h1>
        <p class="sub-title" style="font-size: 1.2em; color: #666; margin-top: 10px;">A meticulously curated gallery of
            premium basketball & sports cards.</p>
    </header>
    <div style="margin: 40px 0; display: flex; justify-content: center; gap: 20px; flex-wrap: wrap;">
        <a href="Juwan-Howard-Collection.html" class="modern-button"
           style="font-size: 1.1em; padding: 15px 30px !important; min-height: 60px;">Explore Main Collection</a>
        <a href="Panini.html" class="modern-button"
           style="font-size: 1.1em; padding: 15px 30px !important; min-height: 60px; background-color: #3264af;">View
            Modern Panini</a>
    </div>
    <div class="ai-summary"
         style="max-width: 800px; margin: 40px auto 0; text-align: left; line-height: 1.8; background: #f9f9f9; padding: 30px; border-radius: 8px; border-left: 5px solid #3a7504;">
        <h3 style="margin-top: 0; color: #333;">About the Archive</h3>
        <p style="margin: 0; color: #555;">This digital archive represents decades of collecting, focusing on high-end
            90s inserts, rare 1-of-1s, and iconic rookie cards. Explore the technical specifications, verified OCR
            back-scans, and the historical significance behind each piece. Every card has been digitized and cataloged
            to preserve hobby history.</p>
    </div>
</main>
${footerHtml?no_esc}
</body>
</html>